{
  "name": "firebase-migration",
  "version": "1.0.0",
  "description": "Data migration script from MySQL to Firebase Firestore",
  "main": "migrate.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "migrate": "node migrate.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!jest.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
